{
  "name": "taskmarket-contracts",
  "version": "1.0.0",
  "description": "Task Market Protocol — Solidity interfaces, reference implementation, and EIP drafts (TMP/PGTR)",
  "license": "MIT",
  "homepage": "https://github.com/daydreamsai/taskmarket-contracts",
  "repository": {
    "type": "git",
    "url": "https://github.com/daydreamsai/taskmarket-contracts.git"
  },
  "exports": {
    "./abi": "./abi/index.ts"
  },
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "test:gas": "forge test --gas-report",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "deploy:local": "forge script script/Deploy.s.sol --rpc-url localhost --broadcast",
    "deploy:testnet": "forge script script/DeployTestnet.s.sol --rpc-url base_sepolia --broadcast --verify",
    "deploy:mainnet": "forge script script/Deploy.s.sol --rpc-url base --broadcast --verify",
    "clean": "forge clean"
  }
}
